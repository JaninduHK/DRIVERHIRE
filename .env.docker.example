# ============================================================================
# Root .env for docker compose  —  copy to ".env":   cp .env.docker.example .env
#
# These values are used by docker-compose.yml for:
#   - variable substitution (${...})
#   - frontend BUILD ARGS (VITE_* are baked into the bundle at build time)
#
# Backend runtime secrets (MONGO_URI, JWT_SECRET, BREVO_API_KEY, etc.) live in
# backend/.env  — copy backend/.env.example to backend/.env separately.
# ============================================================================

# ---- Frontend build-time variables (Vite) ----
# Leave VITE_API_URL as /api so the browser talks to the same origin via nginx.
VITE_API_URL=/api
VITE_GA_MEASUREMENT_ID=
VITE_GOOGLE_MAPS_API_KEY=
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---- MongoDB (optional auth) ----
# Leave blank to run MongoDB without authentication (fine for an isolated,
# non-published container). If you set these, update MONGO_URI in backend/.env:
#   MONGO_URI=mongodb://USER:PASS@mongo:27017/driverhire?authSource=admin
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
